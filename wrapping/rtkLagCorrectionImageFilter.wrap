itk_wrap_class("rtk::LagCorrectionImageFilter" POINTER)
  foreach(t ${WRAP_ITK_REAL})
    foreach(modelOrder 1 2 3 4)
      itk_wrap_template("I${ITKM_${t}}3${modelOrder}" "itk::Image<${ITKT_${t}}, 3>, ${modelOrder}")
    endforeach()
  endforeach()
  if(RTK_USE_CUDA)
    itk_wrap_include(itkCudaImage.h)
    itk_wrap_template("CI${ITKM_US}34" "itk::CudaImage<${ITKT_US}, 3>, 4")
  endif()

itk_end_wrap_class()
