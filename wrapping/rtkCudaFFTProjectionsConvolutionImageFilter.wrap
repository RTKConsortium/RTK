if(RTK_USE_CUDA)
  itk_wrap_include(rtkScatterGlareCorrectionImageFilter.h)
  itk_wrap_include(rtkFFTRampImageFilter.h)

  itk_wrap_class("rtk::CudaFFTProjectionsConvolutionImageFilter" POINTER)
    itk_wrap_template("SGCI${ITKM_F}3CI${ITKM_F}3F" "rtk::ScatterGlareCorrectionImageFilter<itk::CudaImage<${ITKT_F}, 3>, itk::CudaImage<${ITKT_F}, 3>, float>")
    itk_wrap_template("RFCI${ITKM_F}3CI${ITKM_F}3F" "rtk::FFTRampImageFilter<itk::CudaImage<${ITKT_F}, 3>, itk::CudaImage<${ITKT_F}, 3>, float>")
  itk_end_wrap_class()
endif()
