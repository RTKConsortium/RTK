if(RTK_USE_CUDA)
  itk_wrap_include(itkCudaImage.h)
endif()

itk_wrap_class("rtk::FDKWeightProjectionFilter" POINTER)
  itk_wrap_image_filter("${WRAP_ITK_REAL}" 2)
  if(RTK_USE_CUDA)
    itk_wrap_template("CI${ITKM_F}3CI${ITKM_F}3F" "itk::CudaImage<${ITKT_F}, 3>" "itk::CudaImage<${ITKT_F}, 3>" "${ITKT_F}")
  endif()
itk_end_wrap_class()
