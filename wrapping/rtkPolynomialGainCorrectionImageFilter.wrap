itk_wrap_class("rtk::PolynomialGainCorrectionImageFilter" POINTER)
  itk_wrap_image_filter("${WRAP_ITK_REAL}" 2 3)

  if(RTK_USE_CUDA)
    itk_wrap_include(itkCudaImage.h)
    itk_wrap_template("CI${ITKM_US}3CI${ITKM_F}3"
      "itk::CudaImage<${ITKT_US}, 3>, itk::CudaImage<${ITKT_F}, 3>")
  endif()

itk_end_wrap_class()
